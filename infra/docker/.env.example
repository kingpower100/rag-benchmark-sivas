# Copy this file to .env and set real values.
# .env is git-ignored; this file is committed as a template only.

# PostgreSQL DSN — used by scripts/init_pgvector.py and scripts/index_pgvector.py.
# When services are started from infra/docker/, connect from the host:
PGVECTOR_DSN=postgresql://rag:rag@localhost:5432/rag

# Elasticsearch base URL — used as CLI default in scripts/init_elasticsearch.py
# and scripts/index_elasticsearch.py.
ELASTICSEARCH_URL=http://localhost:9200
